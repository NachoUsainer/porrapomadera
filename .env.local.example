# Copia este archivo a ".env.local" y rellena los valores con los de tu proyecto de Supabase.
# Los encuentras en Supabase -> Project Settings -> API

# URL del proyecto (ej: https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave "service_role" (SECRETA, solo se usa en el servidor). NO la del navegador.
SUPABASE_SERVICE_ROLE_KEY=

# Contraseña para entrar al panel de administración (la eliges tú)
ADMIN_PASSWORD=cambia-esto

# Secreto para firmar las cookies de sesión (pon una cadena larga y aleatoria)
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio
